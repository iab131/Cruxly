generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id // Clerk ID (user_...)
  username  String?
  image     String?
  bio       String?
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  problems  Problem[]

  @@map("users")
}

model Problem {
  id          String   @id @default(uuid())
  name        String
  grade       String
  gym         String
  image       String?  @map("image_url")
  type        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])

  @@map("problems")
}
