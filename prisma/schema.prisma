generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  bio       String?
  image     String?  // For avatar
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  setProblems Problem[] @relation("Setter")

  @@map("users")
}

model Problem {
  id          String   @id @default(uuid())
  name        String
  grade       String
  gym         String
  image       String?  @map("image_url")
  type        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  setterId    String?  @map("setter_id")
  setter      User?    @relation("Setter", fields: [setterId], references: [id])

  @@map("problems")
}
